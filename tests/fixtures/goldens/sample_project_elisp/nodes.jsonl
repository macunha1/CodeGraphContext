{"_id": {"offset": 0, "table": 4}, "path": "./foo-core.el", "name": "foo-core-format", "is_dependency": false, "lang": "elisp", "line_number": 21, "uid": "foo-core-format/home/shashank/Desktop/cgc/CodeGraphContext/tests/fixtures/sample_projects/sample_project_elisp/foo-core.el21", "end_line": 27, "source": "(defun foo-core-format (name &optional loud)\n  \"Build a greeting for NAME.\nWhen LOUD is non-nil, uppercase the greeting.\"\n  (let ((greeting (format \"Hello, %s\" name)))\n    (if loud\n        (upcase greeting)\n      greeting)))", "docstring": "Build a greeting for NAME.\nWhen LOUD is non-nil, uppercase the greeting.", "cyclomatic_complexity": 2, "decorators": [""], "args": ["name", "loud"], "_labels": ["Function"]}
{"_id": {"offset": 1, "table": 4}, "path": "./foo-core.el", "name": "foo-core-increment", "is_dependency": false, "lang": "elisp", "line_number": 29, "uid": "foo-core-increment/home/shashank/Desktop/cgc/CodeGraphContext/tests/fixtures/sample_projects/sample_project_elisp/foo-core.el29", "end_line": 31, "source": "(defsubst foo-core-increment (value)\n  \"Increment VALUE.\"\n  (1+ value))", "docstring": "Increment VALUE.", "cyclomatic_complexity": 1, "decorators": [""], "args": ["value"], "_labels": ["Function"]}
{"_id": {"offset": 2, "table": 4}, "path": "./foo-core.el", "name": "foo-core-with-name", "is_dependency": false, "lang": "elisp", "line_number": 33, "uid": "foo-core-with-name/home/shashank/Desktop/cgc/CodeGraphContext/tests/fixtures/sample_projects/sample_project_elisp/foo-core.el33", "end_line": 36, "source": "(defmacro foo-core-with-name (name &rest body)\n  \"Bind NAME around BODY.\"\n  `(let ((current-name ,name))\n     ,@body))", "docstring": "Bind NAME around BODY.", "cyclomatic_complexity": 1, "decorators": [""], "args": ["name", "body"], "_labels": ["Function"]}
{"_id": {"offset": 3, "table": 4}, "path": "./foo-core.el", "name": "foo-core-greet", "is_dependency": false, "lang": "elisp", "line_number": 38, "uid": "foo-core-greet/home/shashank/Desktop/cgc/CodeGraphContext/tests/fixtures/sample_projects/sample_project_elisp/foo-core.el38", "end_line": 41, "source": "(cl-defun foo-core-greet (&key (name foo-core-default-name) loud)\n  \"Return a greeting using keyword arguments.\"\n  (setq foo-core-count (foo-core-increment foo-core-count))\n  (foo-core-format name loud))", "docstring": "Return a greeting using keyword arguments.", "cyclomatic_complexity": 1, "decorators": [""], "args": ["name", "loud"], "_labels": ["Function"]}
{"_id": {"offset": 4, "table": 4}, "path": "./foo-ui.el", "name": "foo-ui-render", "is_dependency": false, "lang": "elisp", "line_number": 12, "uid": "foo-ui-render/home/shashank/Desktop/cgc/CodeGraphContext/tests/fixtures/sample_projects/sample_project_elisp/foo-ui.el12", "end_line": 16, "source": "(defun foo-ui-render (name)\n  \"Render a greeting for NAME.\"\n  (message \"%s\" (foo-core-greet :name name))\n  (funcall #'foo-ui-after-render name)\n  (apply #'foo-ui-log (list name)))", "docstring": "Render a greeting for NAME.", "cyclomatic_complexity": 1, "decorators": [""], "args": ["name"], "_labels": ["Function"]}
{"_id": {"offset": 5, "table": 4}, "path": "./foo-ui.el", "name": "foo-ui-after-render", "is_dependency": false, "lang": "elisp", "line_number": 18, "uid": "foo-ui-after-render/home/shashank/Desktop/cgc/CodeGraphContext/tests/fixtures/sample_projects/sample_project_elisp/foo-ui.el18", "end_line": 20, "source": "(defun foo-ui-after-render (name)\n  \"Hook run after rendering NAME.\"\n  (message \"Rendered %s\" name))", "docstring": "Hook run after rendering NAME.", "cyclomatic_complexity": 1, "decorators": [""], "args": ["name"], "_labels": ["Function"]}
